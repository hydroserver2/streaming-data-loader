{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "SDL: Dev",
      "type": "debugpy",
      "request": "launch",
      "module": "sidecar.main",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "preLaunchTask": "SDL: Dev Services",
      "envFile": "${workspaceFolder}/.env.development",
      "python": "${workspaceFolder}/.venv/bin/python",
      "windows": {
        "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe"
      },
      "env": {
        "PYTHONUNBUFFERED": "1"
      }
    }
  ]
}
