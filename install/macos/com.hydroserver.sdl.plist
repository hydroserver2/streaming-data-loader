<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.hydroserver.sdl</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Library/Application Support/HydroServerSDL/bin/sdl-service</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/Library/Application Support/HydroServerSDL/logs/service.log</string>
    <key>StandardErrorPath</key>
    <string>/Library/Application Support/HydroServerSDL/logs/service-error.log</string>
    <key>WorkingDirectory</key>
    <string>/Library/Application Support/HydroServerSDL</string>
</dict>
</plist>
